IDD_IMPORT_FROM_HISTORY DIALOGEX 0, 0, 267, 380
STYLE DS_SETFONT | DS_MODALFRAME | WS_POPUP | WS_CAPTION | WS_SYSMENU
CAPTION "导入海外版本的scene文件"
FONT 10, "宋体", 0, 0, 0x1
BEGIN
    PUSHBUTTON      "更新当前版本(&R)",ID_REFRESH,71,359,62,14
    PUSHBUTTON      "关闭(&C)",IDCANCEL,148,359,47,14
    LTEXT           "海外版本场景文件路径：",IDC_STATIC,7,7,85,8
    EDITTEXT        IDC_EDIT_HISTROY_SCENE,7,17,145,14,ES_AUTOHSCROLL
    PUSHBUTTON      "打开(&O)",IDC_IMPORT_SCENE,157,18,39,14
    CONTROL         "List1",IDC_NPC_INFO_LIST,"SysListView32",LVS_REPORT | WS_BORDER | WS_TABSTOP,7,52,253,240,WS_EX_CLIENTEDGE
    PUSHBUTTON      "加载并对比(&L)",IDC_COMPARE_WITH_CURR,202,18,55,14
    LTEXT           "对比结果：",IDC_STATIC,7,41,38,8
    LTEXT           "注意：\r\n1. 本功能制作初衷用于解决海外更新版本过多、数据过杂问题；\r\n2. 必须导入正确的1.scene文件才可以进行覆盖；\r\n3. 覆盖所做的任何修改，不可以上传到服务器上，必须undo checkout处理，以保证国内服务器数据的正确性；\r\n4. 除制作海外更新地图的相关人员，禁止使用本项功能。",IDC_STATIC,9,300,246,55
END

