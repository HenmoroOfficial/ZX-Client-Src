    VK_DELETE,      ID_OPERATION_DELETE,    VIRTKEY, NOINVERT
    "2",            ID_OPERATION_MOVE,      VIRTKEY, NOINVERT
    "Y",            ID_OPERATION_REDO,      VIRTKEY, CONTROL, NOINVERT
