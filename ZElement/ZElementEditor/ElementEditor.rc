IDR_MAINFRAME MENU 
BEGIN
    POPUP "文件(&F)"
    BEGIN
        MENUITEM "设置工作空间",                      ID_SET_WORKSPACE
        MENUITEM SEPARATOR
        MENUITEM "新建(&N) ...\tCtrl+N",          ID_FILE_NEW
        MENUITEM "打开(&O)...\tCtrl+O",           ID_FILE_OPEN
        MENUITEM "关闭",                          ID_FILE_CLOSE
        MENUITEM SEPARATOR
        MENUITEM "保存(&S)\tCtrl+S",              ID_FILE_SAVE
        MENUITEM "另存为...",                      ID_FILE_SAVEAS
        MENUITEM SEPARATOR
        MENUITEM "导出游戏数据...",                   ID_FILE_EXPORTGAMEDATA
        MENUITEM "导出游戏资源...",                   ID_EXPORT_GAME_RES
        MENUITEM "输出顶视图...",                    ID_EXP_TOPVIEW_MAP
        MENUITEM SEPARATOR
        MENUITEM "调整所有场景对象高度...",               ID_MOVE_ALL_SCENE_OBJECT
        MENUITEM "自动切分高度图...",                  ID_FILE_AUTOPARTHM
        MENUITEM "重新排列地图...",                   ID_FILE_SORT_MAP
        MENUITEM SEPARATOR
        MENUITEM "设置工作路径...",                   ID_FILE_SETWORKDIR
        MENUITEM SEPARATOR
        MENUITEM "测试项目管辖区域覆盖情况",                ID_TEST_PRECINCT_ERROR
        MENUITEM SEPARATOR
        MENUITEM "导出AI数据",                      ID_EXP_AI_DATA
        MENUITEM "输入AI数据",                      ID_IMP_AI_DATA
        MENUITEM SEPARATOR
        MENUITEM "输出项目中用到过的天空纹理",               ID_EXPORT_SKY_INFOR
        MENUITEM "输出当前项目灯光列表",                  ID_EXP_LIGHT_INFOR_LIST
        MENUITEM SEPARATOR
        MENUITEM "导出游戏信息列表(&E)",                ID_EXPORT_INFO
        MENUITEM SEPARATOR
        MENUITEM "退出(&X)",                      ID_APP_EXIT
    END
    POPUP "查看(&V)"
    BEGIN
        MENUITEM "工具栏(&T)",                     ID_VIEW_TOOLBAR
        MENUITEM "状态栏(&S)",                     ID_VIEW_STATUS_BAR
        MENUITEM SEPARATOR
        MENUITEM "重置摄像机位置",                     ID_VIEW_RESETCAMERA
        MENUITEM "重新加载所有纹理",                    ID_RELOAD_ALL_TEXTURES
    END
    POPUP "编辑(&E)"
    BEGIN
        MENUITEM "撤消(&U)\tCtrl+Z",              ID_EDIT_UNDO
        MENUITEM SEPARATOR
        MENUITEM "剪切(&T)\tCtrl+X",              ID_EDIT_CUT
        MENUITEM "复制(&C)\tCtrl+C",              ID_EDIT_COPY
        MENUITEM "粘贴(&P)\tCtrl+V",              ID_EDIT_PASTE
        MENUITEM SEPARATOR
        MENUITEM "使用光照图",                       ID_ENABLELITMAP
        MENUITEM "实时光照（预览）",                    ID_ENABLE_REALTIME_LIGHT
        MENUITEM "使用细节图",                       32923
    END
    POPUP "地形(&R)"
    BEGIN
        MENUITEM "高度图...",                      ID_TERRAIN_HEIGHTMAP
        MENUITEM "贴图层...",                      ID_TERRAIN_SURACES
        MENUITEM "光照...",                       ID_TERRAIN_LIGHTING
        MENUITEM SEPARATOR
        MENUITEM "更新地形渲染数据",                    ID_TERRAIN_CREATESURFS
        MENUITEM SEPARATOR
        MENUITEM "修改地形障碍图...",                  ID_TERRAIN_MODIFIED_PROFILE
        MENUITEM SEPARATOR
        MENUITEM "地图自动拼接\tCtrl+L",              ID_MAP_AUTO_MERGE
        MENUITEM "显示地形纹理分布状态\tCtrl+B",          ID_TERRAIN_BLOCK_VIEW
    END
    POPUP "工具(&T)"
    BEGIN
        MENUITEM "资源管理器",                       ID_MENU_RES_MAN
        MENUITEM SEPARATOR
        MENUITEM "测试区域是否完全覆盖",                  ID_TEST_PRECINCT
        MENUITEM "对场景中树优化处理",                   ID_MERGE_TREE_TYPE
        MENUITEM SEPARATOR
        MENUITEM "把列表中的怪物插入到地图",                ID_INSERT_MOUNSTER_TO_MAP
        MENUITEM "重新加载NPC",                     ID_RELOAD_NPC
        MENUITEM "统计地图中怪物数",                    ID_MOUNSTER_STAT
        MENUITEM SEPARATOR
        MENUITEM "统计项目中模型更改情况",                 ID_MODEL_CHANGED
        MENUITEM "统计场景中所有三角形数",                 ID_STAT_ALL_TRIANGLE
        MENUITEM "统计地图中的背景音乐",                  ID_STAT_MUSIC
        MENUITEM SEPARATOR
        MENUITEM "动态对象编辑器",                     ID_DYNAMIC_OBJECT_EDITOR
        MENUITEM "怪物控制器编辑(&M)",                 ID_MONSTER_CONTROLLER_EDITOR
    END
    POPUP "光照"
    BEGIN
        MENUITEM "计算场景光照图利用率",                  ID_CALC_LIGHTMAP_RATE
        MENUITEM "删除选中对象的光照图",                  ID_DELSELOBJLITMAP
        MENUITEM "重新加载光照图和顶点光",                 ID_RELOADLITMAP
        MENUITEM "重新加载光照图（不加载顶点光）",             ID_RELOADLITMAP_NOVERT
        MENUITEM "光线追踪渲染光照图",                   IDM_RAYTRACE_LIGHTMAP_WIZARD
    END
    POPUP "VSS"
    BEGIN
        MENUITEM "配置VSS",                       ID_SET_VSS
        MENUITEM SEPARATOR
        MENUITEM "取最新资源数据",                     ID_GET_VSS_ALL
        MENUITEM SEPARATOR
        MENUITEM "取得最新全部地图数据",                  ID_GET_ALL_MAP_DATA
        MENUITEM "取得当前工作空间所有地图",                ID_GET_CURRENT_PROJ_WORKSPACE_MAPS
        MENUITEM SEPARATOR
        MENUITEM "把地图放回服务器(CHECK IN)",          VSS_TEST_MAP_CHECKIN
    END
    POPUP "海外专用(&O)"
    BEGIN
        MENUITEM "从海外版本更新(&H)",                 ID_IMPORT_HISTORY
    END
    POPUP "帮助(&H)"
    BEGIN
        MENUITEM "更新历史",                        ID_APP_ABOUT
    END
END

