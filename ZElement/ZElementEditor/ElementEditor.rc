    "4",            ID_OPERATION_ROTATE2,   VIRTKEY, NOINVERT
    "5",            ID_OPERATION_SCALE,     VIRTKEY, NOINVERT
    "1",            ID_OPERATION_SELECT,    VIRTKEY, NOINVERT
    "6",            ID_OPERATION_SELECTMULTI, VIRTKEY, NOINVERT
    "Z",            ID_OPERATION_UNDO,      VIRTKEY, CONTROL, NOINVERT
