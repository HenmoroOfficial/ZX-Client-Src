	public:
		int roleid;
		unsigned int localsid;
		Octets msg;
		char repost;
		enum { PROTOCOL_TYPE = PROTOCOL_FACTIONPOSTMSG };
	public:
		FactionPostMsg() { type = PROTOCOL_FACTIONPOSTMSG; }
		FactionPostMsg(void*) : Protocol(PROTOCOL_FACTIONPOSTMSG) { }
		FactionPostMsg (int l_roleid,unsigned int l_localsid = 0,const Octets& l_msg = Octets(),
			char l_repost = 0)
			 : roleid(l_roleid),localsid(l_localsid),msg(l_msg)
			,repost(l_repost)
		{
			type = PROTOCOL_FACTIONPOSTMSG;
		}

		FactionPostMsg(const FactionPostMsg &rhs)
			: Protocol(rhs),roleid(rhs.roleid),localsid(rhs.localsid),msg(rhs.msg)
			,repost(rhs.repost) { }

		GNET::Protocol *Clone() const { return new FactionPostMsg(*this); }

		OctetsStream& marshal(OctetsStream & os) const
		{
			os << roleid;
			os << localsid;
			os << msg;
			os << repost;
			return os;
		}

		const OctetsStream& unmarshal(const OctetsStream &os)
		{
			os >> roleid;
			os >> localsid;
			os >> msg;
			os >> repost;
			return os;
		}

		int PriorPolicy( ) const { return 1; }

		bool SizePolicy(size_t size) const { return size <= 1024; }
