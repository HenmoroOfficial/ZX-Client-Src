		OctetsStream& marshal(OctetsStream & os) const
		{
			os << retcode;
			os << status;
			os << cities;
			os << localsid;
			return os;
		}

		const OctetsStream& unmarshal(const OctetsStream &os)
		{
			os >> retcode;
			os >> status;
			os >> cities;
			os >> localsid;
			return os;
		}

