#ifndef __GNET_GBATTLECHALLENGE_RPCDATA
#define __GNET_GBATTLECHALLENGE_RPCDATA

#include "rpcdefs.h"


namespace GNET
{
	class GBattleChallenge : public GNET::Rpc::Data
	{
	public:
		short id;
		unsigned int challenger1;
		unsigned int challenger2;
		unsigned int credit1;
		unsigned int credit2;
		unsigned int cutoff_time;

	public:
		GBattleChallenge (short l_id = 0,unsigned int l_challenger1 = 0,unsigned int l_challenger2 = 0
			,unsigned int l_credit1 = 0,unsigned int l_credit2 = 0,unsigned int l_cutoff_time = 0)
			: id(l_id),challenger1(l_challenger1),challenger2(l_challenger2)
			,credit1(l_credit1),credit2(l_credit2),cutoff_time(l_cutoff_time)
		{
		}

		GBattleChallenge(const GBattleChallenge &rhs)
			: id(rhs.id),challenger1(rhs.challenger1),challenger2(rhs.challenger2),
			credit1(rhs.credit1),credit2(rhs.credit2),cutoff_time(rhs.cutoff_time) { }

		Rpc::Data *Clone() const { return new GBattleChallenge(*this); }

		Rpc::Data& operator = (const Rpc::Data &rhs)
		{
			const GBattleChallenge *r = dynamic_cast<const GBattleChallenge *>(&rhs);
			if (r && r != this)
			{
				id = r->id;
				challenger1 = r->challenger1;
				challenger2 = r->challenger2;
				credit1 = r->credit1;
				credit2 = r->credit2;
				cutoff_time = r->cutoff_time;
			}
			return *this;
		}

		GBattleChallenge& operator = (const GBattleChallenge &rhs)
		{
			const GBattleChallenge *r = &rhs;
			if (r && r != this)
			{
				id = r->id;
				challenger1 = r->challenger1;
				challenger2 = r->challenger2;
				credit1 = r->credit1;
				credit2 = r->credit2;
				cutoff_time = r->cutoff_time;
			}
			return *this;
		}

		OctetsStream& marshal(OctetsStream & os) const
		{
			os << id;
			os << challenger1;
			os << challenger2;
			os << credit1;
			os << credit2;
			os << cutoff_time;
			return os;
		}

		const OctetsStream& unmarshal(const OctetsStream &os)
		{
			os >> id;
			os >> challenger1;
			os >> challenger2;
			os >> credit1;
			os >> credit2;
			os >> cutoff_time;
			return os;
		}

	};
};
#endif
