IDD_ABOUTBOX DIALOG DISCARDABLE  0, 0, 235, 209
STYLE DS_MODALFRAME | WS_POPUP | WS_CAPTION | WS_SYSMENU
CAPTION "关于 ElementData"
FONT 9, "宋体"
BEGIN
    ICON            IDR_MAINFRAME,IDC_STATIC,7,7,20,20
    LTEXT           "ElementData 1.1 (Q)版",IDC_STATIC,40,10,119,8,
                    SS_NOPREFIX
    DEFPUSHBUTTON   "确定",IDOK,178,7,50,14,WS_GROUP
    ICON            IDI_WRITEABLE,IDC_STATIC,7,65,20,20
    ICON            IDI_OBJECT,IDC_STATIC,7,109,20,20
    LTEXT           "可编辑对象  这种图标的文件你可以修改。修改后可以执行 Check In 操作把修改后的文件放到服务器上！",
                    IDC_STATIC,35,67,193,28
    LTEXT           "只读对象   这种图标的文件你不能修改。如果你想要修改你必须执行 Check Out 操作！",
                    IDC_STATIC,36,112,192,30
    LTEXT           "注意图标：",IDC_STATIC,7,45,41,8
    LTEXT           "当你 Check out 一个文件发现图标的颜色没有改变，那么这个文件很可能已经被其他用户 Check out 了。另外也可能是该文件已经被别人从服务器上删除！你可以用SourceSafe查看一下该文件的状态。",
                    IDC_STATIC,7,155,221,40
END

