/////////////////////////////////////////////////////////////////////////////
//
// Menu
//

IDR_MAINFRAME MENU PRELOAD DISCARDABLE 
BEGIN
    POPUP "文件(&F)"
    BEGIN
        MENUITEM SEPARATOR
        MENUITEM "最近文件",                    ID_FILE_MRU_FILE1, GRAYED
        MENUITEM SEPARATOR
        MENUITEM "退出(&X)",                    ID_APP_EXIT
        MENUITEM "按id查找\tCtrl+I",            ID_FIND_BYID
        MENUITEM "按文件名查找\tCtrl+F",        ID_FIND_BYFILE
        MENUITEM "查找下一个\tF3",              ID_FIND_NEXT
    END
    POPUP "查看(&V)"
    BEGIN
        MENUITEM "工具栏(&T)",                  ID_VIEW_TOOLBAR
        MENUITEM "状态栏(&S)",                  ID_VIEW_STATUS_BAR
    END
    POPUP "帮助(&H)"
    BEGIN
        MENUITEM "关于 ElementData(&A)...",     ID_APP_ABOUT
        MENUITEM "更新日志",                    ID_UPDATE_LOG
    END
    POPUP "VSS"
    BEGIN
        MENUITEM "配置VSS",                     ID_OPTION_VSS
        MENUITEM SEPARATOR
        MENUITEM "取得最新的策略数据",          ID_GET_POLICY_DATA
        MENUITEM "取得最新模板数据",            ID_VSS_FRESH
    END
    POPUP "TOOL"
    BEGIN
        MENUITEM "为所有模板添加一次MD5校验码", ID_TRANS_VERSION, GRAYED
        MENUITEM "怪物掉落重置表编辑",          ID_MOUNSTER_FALL_ITEM_EDITOR
        MENUITEM "生成合并版本对比文件",        ID_MERGE_VERSION_GEN_FILES
        MENUITEM "合并版本",                    ID_MERGE_VERSION
    END
END

IDR_ELEMENTYPE MENU PRELOAD DISCARDABLE 
BEGIN
    POPUP "文件(&F)"
    BEGIN
        MENUITEM "最近文件",                    ID_FILE_MRU_FILE1, GRAYED
        MENUITEM SEPARATOR
        MENUITEM "退出(&X)",                    ID_APP_EXIT
    END
    POPUP "编辑(&E)"
    BEGIN
        MENUITEM "撤消(&U)\tCtrl+Z",            ID_EDIT_UNDO
        MENUITEM SEPARATOR
        MENUITEM "剪切(&T)\tCtrl+X",            ID_EDIT_CUT
        MENUITEM "复制(&C)\tCtrl+C",            ID_EDIT_COPY
        MENUITEM "粘贴(&P)\tCtrl+V",            ID_EDIT_PASTE
    END
    POPUP "查看(&V)"
    BEGIN
        MENUITEM "工具栏(&T)",                  ID_VIEW_TOOLBAR
        MENUITEM "状态栏(&S)",                  ID_VIEW_STATUS_BAR
    END
    POPUP "窗口(&W)"
    BEGIN
        MENUITEM "新建窗口(&N)",                ID_WINDOW_NEW
        MENUITEM "层叠(&C)",                    ID_WINDOW_CASCADE
        MENUITEM "平铺(&T)",                    ID_WINDOW_TILE_HORZ
        MENUITEM "排列图标(&A)",                ID_WINDOW_ARRANGE
        MENUITEM SEPARATOR
        MENUITEM "关闭所有窗口",                ID_CLOSE_ALL_DOC
    END
    POPUP "帮助(&H)"
    BEGIN
        MENUITEM "关于 ElementData(&A)...",     ID_APP_ABOUT
    END
    POPUP "VSS"
    BEGIN
        MENUITEM "配置VSS",                     ID_OPTION_VSS
    END
END

IDR_MENU_CREATE_OBJECT MENU DISCARDABLE 
BEGIN
    POPUP "&&&"
    BEGIN
        MENUITEM "添加基本模板",                ID_CREATE_OBJECT
        MENUITEM "添加附加属性模板",            ID_CREATE_OBJECT_EXT
        MENUITEM "修改附加属性模板",            ID_MODIFIED_OBJECT_EXT
        MENUITEM SEPARATOR
        MENUITEM "编辑模板属性",                ID_EDIT_TEMPLATE_PROPERTY
        MENUITEM SEPARATOR
        MENUITEM "Check In",                    ID_VSS_CHECK_IN
        MENUITEM "Check Out",                   ID_VSS_CHECK_OUT
        MENUITEM SEPARATOR
        MENUITEM "Check In All",                ID_VSS_CHECK_IN_ALL
        MENUITEM "Check Out All",               ID_VSS_CHECK_OUT_ALL
        MENUITEM SEPARATOR
        MENUITEM "Undo Check Out",              ID_VSS_UNDO_CHECK_OUT
    END
END

IDR_MENU_TALK MENU DISCARDABLE 
BEGIN
    POPUP "&"
    BEGIN
        MENUITEM "创建一个新对象",              ID_CREATE_TALK_WINDOW
        MENUITEM "修改对象",                    ID_MODIFY_TALK_WINDOW
    END
END

IDR_MENU_POLICY MENU DISCARDABLE 
BEGIN
    POPUP "test"
    BEGIN
        MENUITEM "创建策略",                    ID_CREATE_POLICY
        MENUITEM SEPARATOR
        MENUITEM "Check out",                   ID_POLICY_CHECK_OUT
        MENUITEM "Check in",                    ID_POLICY_CHECK_IN
    END
END

IDR_MENU_ADD_SUB MENU DISCARDABLE 
BEGIN
    POPUP "test"
    BEGIN
        MENUITEM "删除主类型",                  ID_MENU_DELMAIN
        MENUITEM "新建主类型",                  ID_MENU_ADDMAIN
        MENUITEM SEPARATOR
        MENUITEM "新建子类型",                  ID_MENU_ADDSUB
        MENUITEM "删除子类型",                  ID_MENU_DELSUB
        MENUITEM SEPARATOR
        MENUITEM "新建宝物",                    ID_MENU_ADD_TREASURE
        MENUITEM "删除宝物",                    ID_MENU_DEL_TREASURE
        MENUITEM SEPARATOR
        MENUITEM "下架",                        ID_MENU_DOFF_TREASURE
    END
END

IDR_MENU_QUESTION MENU DISCARDABLE 
BEGIN
    POPUP "test"
    BEGIN
        MENUITEM "创建文件夹",                  ID_CREATE_FOLDER
        MENUITEM SEPARATOR
        MENUITEM "新问题",                      ID_CREATE_QUESTION
        MENUITEM SEPARATOR
        MENUITEM "Check Out",                   ID_QUESTION_CHECK_OUT
        MENUITEM "Check In",                    ID_QUESTION_CHECK_IN
    END
END


